# Production environment template.
#
# Copy to ``.env`` on the VPS and fill in every value. NEVER commit the
# real .env. Generate strong secrets with:
#
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Caddy basic-auth hash:
#
#   docker run --rm caddy:2 caddy hash-password
#
# Fernet key:
#
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ============================================================================
# App
# ============================================================================
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# 32+ char URL-safe secret. Used for the X-Admin-Token *and* internal
# admin-API auth between the Streamlit container and the API container.
APP_SECRET_KEY=

# ============================================================================
# Database — local postgres in the same compose project.
# Set POSTGRES_PASSWORD to something strong; both pieces must match.
# ============================================================================
POSTGRES_DB=poi_lake
POSTGRES_USER=poi
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://poi:${POSTGRES_PASSWORD}@postgres:5432/poi_lake
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=15
DATABASE_ECHO=false

# ============================================================================
# Redis
# ============================================================================
REDIS_URL=redis://redis:6379/0

# ============================================================================
# Anthropic — used by the dedupe LLM resolver (Phase 4).
# Optional: leave blank to fall back to non-LLM scoring (loses some recall
# on ambiguous duplicates).
# ============================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NORMALIZE=claude-sonnet-4-6
ANTHROPIC_MODEL_RESOLVER=claude-opus-4-7

# ============================================================================
# Adapters
# ============================================================================
GOOGLE_PLACES_API_KEY=
VIETMAP_API_KEY=
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
GOSOM_SCRAPER_URL=http://gosom-scraper:8080
FOODY_RATE_LIMIT_PER_SEC=2

# ============================================================================
# Pipeline tuning
# ============================================================================
DEDUPE_CLUSTER_EPS_METERS=55
DEDUPE_AUTO_MERGE_THRESHOLD=0.85
DEDUPE_LLM_THRESHOLD=0.65
DEDUPE_SCHEDULE_MINUTES=15

# ============================================================================
# Embeddings — cached to a named volume across container rebuilds.
# ============================================================================
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_CACHE_DIR=/app/models

# ============================================================================
# Webhooks (Phase 5b — currently no-op until dispatcher is wired up)
# ============================================================================
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=5

# ============================================================================
# Encryption — for sources.config secret fields (e.g. API keys stored on
# Source rows). MUST be set before creating any source with encrypted
# config; rotating breaks decryption of existing rows.
# ============================================================================
FERNET_KEY=

# ============================================================================
# Caddy reverse proxy — public hostnames + ACME contact + admin gate
# ============================================================================
CADDY_API_HOST=api.poi.oohx.net
CADDY_ADMIN_HOST=admin.poi.oohx.net
ACME_EMAIL=ops@oohx.net

# Generate with:  docker run --rm caddy:2 caddy hash-password
# (paste the hash *literally*; it includes $ characters Docker won't expand)
ADMIN_BASIC_AUTH_HASH=

# ============================================================================
# Backup — uploaded daily by the cron job in scripts/backup_postgres.sh
# ============================================================================
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=poi-lake/postgres
BACKUP_RETENTION_DAYS=14
# AWS creds for the backup uploader. Use a dedicated IAM principal scoped
# to s3:PutObject on the prefix above and nothing else.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
